{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["level", "families"],
  "properties": {
    "level": {"type": "string"},
    "families": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["family_id", "family_name", "family_lead", "family_hook", "progression_line", "member_ids"],
        "properties": {
          "family_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "family_name": {"type": "string", "minLength": 2},
          "family_lead": {"type": "string", "minLength": 6},
          "family_hook": {"type": "string", "minLength": 6},
          "progression_line": {"type": "string", "minLength": 4},
          "member_ids": {
            "type": "array",
            "minItems": 3,
            "items": {"type": "string", "pattern": "^n[1-5]_[0-9]{3}_[a-z0-9_]+$"}
          }
        }
      }
    }
  }
}
