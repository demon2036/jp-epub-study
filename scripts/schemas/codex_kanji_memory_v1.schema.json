{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codex_kanji_memory_v1.schema.json",
  "title": "Codex Kanji Memory v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "semantic_core",
    "readings",
    "scenario_contrast_groups",
    "homophone_groups",
    "near_synonym_groups",
    "same_kanji_expansion_groups",
    "pitfalls",
    "memory_chain"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "semantic_core": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core",
        "extension",
        "root_hint"
      ],
      "properties": {
        "core": { "type": "string", "minLength": 4 },
        "extension": { "type": "string", "minLength": 8 },
        "root_hint": { "type": "string", "minLength": 6 }
      }
    },
    "readings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
          "required": [
            "kana",
            "romaji",
            "type",
            "usage",
            "origin_hint",
            "example_sentence",
            "anchor",
            "examples",
            "takeaway"
          ],
          "properties": {
          "kana": { "type": "string", "minLength": 1 },
            "romaji": { "type": "string", "minLength": 1 },
            "type": { "type": "string", "minLength": 1 },
            "usage": { "type": "string", "minLength": 6 },
            "origin_hint": { "type": "string", "minLength": 4 },
            "example_sentence": {
              "type": "object",
              "additionalProperties": false,
              "required": ["jp_ruby", "kana", "mandarin_pronunciation", "zh", "note"],
              "properties": {
                "jp_ruby": {
                  "type": "string",
                  "pattern": "^(?:[^\\[\\]]|[一-龯々〆ヵヶ]+\\[[ぁ-ゖァ-ヺー]+\\])+$"
                },
                "kana": { "type": "string", "minLength": 4 },
                "mandarin_pronunciation": {
                  "type": "string",
                  "pattern": "^[A-Za-züÜāáǎàēéěèīíǐìōóǒòūúǔùǖǘǚǜĀÁǍÀĒÉĚÈĪÍǏÌŌÓǑÒŪÚǓÙǕǗǙǛńňǹḿŃŇǸḾ:’' -]+$"
                },
                "zh": { "type": "string", "minLength": 2 },
                "note": { "type": "string", "minLength": 6 }
              }
            },
            "anchor": {
              "type": "object",
              "additionalProperties": false,
            "required": [
              "word",
              "reading",
              "meaning",
              "hint"
            ],
            "properties": {
              "word": { "type": "string", "minLength": 1 },
              "reading": { "type": "string", "minLength": 1 },
              "meaning": { "type": "string", "minLength": 1 },
              "hint": { "type": "string", "minLength": 6 }
            }
          },
          "examples": {
            "type": "array",
            "minItems": 2,
            "items": { "$ref": "#/$defs/readingExample" }
          }
          ,
          "takeaway": { "type": "string", "minLength": 8 }
        }
      }
    },
    "scenario_contrast_groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/groupWithTargetReading" }
    },
    "homophone_groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/homophoneGroup" }
    },
    "near_synonym_groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/groupWithoutTargetReading" }
    },
    "same_kanji_expansion_groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/groupWithTargetReading" }
    },
    "pitfalls": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string" }
    },
    "memory_chain": {
      "type": "string",
      "minLength": 30
    }
  },
  "$defs": {
    "readingExample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "word",
        "reading",
        "meaning",
        "link"
      ],
      "properties": {
        "word": { "type": "string", "minLength": 1 },
        "reading": { "type": "string", "minLength": 1 },
        "meaning": { "type": "string", "minLength": 1 },
        "link": { "type": "string", "minLength": 6 }
      }
    },
    "groupItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "word",
        "reading",
        "meaning",
        "relation",
        "note"
      ],
      "properties": {
        "word": { "type": "string", "minLength": 1 },
        "reading": { "type": "string", "minLength": 1 },
        "meaning": { "type": "string", "minLength": 1 },
        "relation": { "type": "string", "minLength": 2 },
        "note": { "type": "string", "minLength": 6 }
      }
    },
    "homophoneItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "word",
        "reading",
        "meaning",
        "relation",
        "note",
        "source_note",
        "memory_hook"
      ],
      "properties": {
        "word": { "type": "string", "minLength": 1 },
        "reading": { "type": "string", "minLength": 1 },
        "meaning": { "type": "string", "minLength": 1 },
        "relation": { "type": "string", "minLength": 2 },
        "note": { "type": "string", "minLength": 6 },
        "source_note": { "type": "string", "minLength": 8 },
        "memory_hook": { "type": "string", "minLength": 6 }
      }
    },
    "groupWithTargetReading": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_reading",
        "title",
        "why_it_works",
        "items",
        "takeaway"
      ],
      "properties": {
        "target_reading": {
          "type": ["string", "null"]
        },
        "title": { "type": "string", "minLength": 4 },
        "why_it_works": { "type": "string", "minLength": 8 },
        "items": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/groupItem" }
        },
        "takeaway": { "type": "string", "minLength": 8 }
      }
    },
    "groupWithoutTargetReading": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "why_it_works",
        "items",
        "takeaway"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 4 },
        "why_it_works": { "type": "string", "minLength": 8 },
        "items": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/groupItem" }
        },
        "takeaway": { "type": "string", "minLength": 8 }
      }
    },
    "homophoneGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_reading",
        "same_kana",
        "title",
        "origin_pattern",
        "same_kana_reason",
        "teaching_point",
        "why_it_works",
        "items",
        "takeaway"
      ],
      "properties": {
        "target_reading": { "type": "string", "minLength": 1 },
        "same_kana": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 4 },
        "origin_pattern": {
          "type": "string",
          "enum": [
            "同源分化",
            "纯同音碰撞",
            "混合型",
            "音读汇合",
            "汉字借写",
            "不确定"
          ]
        },
        "same_kana_reason": { "type": "string", "minLength": 12 },
        "teaching_point": { "type": "string", "minLength": 8 },
        "why_it_works": { "type": "string", "minLength": 8 },
        "items": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/homophoneItem" }
        },
        "takeaway": { "type": "string", "minLength": 8 }
      }
    }
  }
}
