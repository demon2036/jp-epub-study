{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entry_id",
    "card_blurb",
    "feel",
    "family_position",
    "scene_paragraph",
    "scene_examples",
    "formula",
    "formula_explainer",
    "structure_cards",
    "usage_points",
    "contrasts",
    "memory_chain"
  ],
  "properties": {
    "entry_id": {"type": "string", "pattern": "^n[1-5]_[0-9]{3}_[a-z0-9_]+$"},
    "card_blurb": {"type": "string", "minLength": 6},
    "feel": {"type": "string", "minLength": 8},
    "family_position": {"type": "string", "minLength": 8},
    "scene_paragraph": {"type": "string", "minLength": 20},
    "scene_examples": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"$ref": "#/$defs/example"}
    },
    "formula": {"type": "string", "minLength": 4},
    "formula_explainer": {"type": "string", "minLength": 10},
    "structure_cards": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "note", "jp_ruby", "zh", "mini_note"],
        "properties": {
          "label": {"type": "string", "minLength": 2},
          "note": {"type": "string", "minLength": 4},
          "jp_ruby": {"$ref": "#/$defs/jp_ruby_line"},
          "zh": {"type": "string", "minLength": 4},
          "mini_note": {"type": "string", "minLength": 4}
        }
      }
    },
    "usage_points": {
      "type": "array",
      "minItems": 4,
      "maxItems": 6,
      "items": {"type": "string", "minLength": 8}
    },
    "contrasts": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "other_entry_id",
          "title",
          "self_label",
          "other_label",
          "difference",
          "example_self",
          "example_other",
          "exam_handle"
        ],
        "properties": {
          "other_entry_id": {"type": "string", "pattern": "^n[1-5]_[0-9]{3}_[a-z0-9_]+$"},
          "title": {"type": "string", "minLength": 5},
          "self_label": {"type": "string", "minLength": 1},
          "other_label": {"type": "string", "minLength": 1},
          "difference": {"type": "string", "minLength": 16},
          "example_self": {"$ref": "#/$defs/example_no_tag"},
          "example_other": {"$ref": "#/$defs/example_no_tag"},
          "exam_handle": {"type": "string", "minLength": 8}
        }
      }
    },
    "memory_chain": {"type": "string", "minLength": 18}
  },
  "$defs": {
    "jp_ruby_line": {
      "type": "string",
      "minLength": 2,
      "pattern": "^(?:[^\\[\\]]|[一-龯々〆ヵヶ]+\\[[ぁ-ゖー]+\\])+$",
      "description": "Use bracket ruby only on kanji chunks, e.g. 口[くち]コミ, 申[もう]し込[こ]み; never annotate a mixed-script whole word like 口コミ[くちこみ]."
    },
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "jp_ruby", "zh", "note"],
      "properties": {
        "tag": {"type": "string", "minLength": 2},
        "jp_ruby": {"$ref": "#/$defs/jp_ruby_line"},
        "zh": {"type": "string", "minLength": 4},
        "note": {"type": "string", "minLength": 4}
      }
    },
    "example_no_tag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jp_ruby", "zh", "note"],
      "properties": {
        "jp_ruby": {"$ref": "#/$defs/jp_ruby_line"},
        "zh": {"type": "string", "minLength": 4},
        "note": {"type": "string", "minLength": 4}
      }
    }
  }
}
