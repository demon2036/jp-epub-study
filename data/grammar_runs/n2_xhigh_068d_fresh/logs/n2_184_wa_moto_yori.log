\\\"},\\\"zh\\\":{\\\"type\\\":\\\"string\\\"},\\\"note\\\":{\\\"type\\\":\\\"string\\\"}}},\\\"exam_handle\\\":{\\\"type\\\":\\\"string\\\"}}}},\n    \\\"memory_chain\\\":{\\\"type\\\":\\\"string\\\"}\n  }\n}\nprint('ok')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
