ng\\\"},\\\"zh\\\":{\\\"type\\\":\\\"string\\\"},\\\"note\\\":{\\\"type\\\":\\\"string\\\"}}},\\\"exam_handle\\\":{\\\"type\\\":\\\"string\\\"}}}},\n    \\\"memory_chain\\\":{\\\"type\\\":\\\"string\\\"}\n  }\n}\nprint('ok')\nPY\"","aggregated_output":"ok\n","exit_code":0,"status":"completed"}}
