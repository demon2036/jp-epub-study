\"minItems\": 4,\n      \"maxItems\": 6,\n      \"items\": {\"type\": \"string\", \"minLength\": 8}\n    },\n    \"contrasts\": {\n      \"type\": \"array\",\n      \"minItems\": 3,\n      \"maxItems\": 3,\n      \"items\": {\n        \"type\": \"object\",\n        \"additionalProperties\": false,\n        \"required\": [\n          \"other_entry_id\",\n          \"title\",\n          \"self_label\",\n          \"other_label\",\n          \"difference\",\n          \"example_self\",\n          \"example_other\",\n          \"exam_handle\"\n        ],\n        \"properties\": {\n          \"other_entry_id\": {\"type\": \"string\", \"pattern\": \"^n[1-5]_[0-9]{3}_[a-z0-9_]+$\"},\n          \"title\": {\"type\": \"string\", \"minLength\": 5},\n          \"self_label\": {\"type\": \"string\", \"minLength\": 1},\n          \"other_label\": {\"type\": \"string\", \"minLength\": 1},\n          \"difference\": {\"type\": \"string\", \"minLength\": 16},\n          \"example_self\": {\"$ref\": \"#/$defs/example_no_tag\"},\n          \"example_other\": {\"$ref\": \"#/$defs/example_no_tag\"},\n          \"exam_handle\": {\"type\": \"string\", \"minLength\": 8}\n        }\n      }\n    },\n    \"memory_chain\": {\"type\": \"string\", \"minLength\": 18}\n  },\n  \"$defs\": {\n    \"jp_ruby_line\": {\n      \"type\": \"string\",\n      \"minLength\": 2,\n      \"pattern\": \"^(?:[^\\\\[\\\\]]|[一-龯々〆ヵヶ]+\\\\[[ぁ-ゖー]+\\\\])+$\",\n      \"description\": \"Use bracket ruby only on kanji chunks, e.g. 口[くち]コミ, 申[もう]し込[こ]み; never annotate a mixed-script whole word like 口コミ[くちこみ].\"\n    },\n    \"example\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"required\": [\"tag\", \"jp_ruby\", \"zh\", \"note\"],\n      \"properties\": {\n        \"tag\": {\"type\": \"string\", \"minLength\": 2},\n        \"jp_ruby\": {\"$ref\": \"#/$defs/jp_ruby_line\"},\n        \"zh\": {\"type\": \"string\", \"minLength\": 4},\n        \"note\": {\"type\": \"string\", \"minLength\": 4}\n      }\n    },\n    \"example_no_tag\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"required\": [\"jp_ruby\", \"zh\", \"note\"],\n      \"properties\": {\n        \"jp_ruby\": {\"$ref\": \"#/$defs/jp_ruby_line\"},\n        \"zh\": {\"type\": \"string\", \"minLength\": 4},\n        \"note\": {\"type\": \"string\", \"minLength\": 4}\n      }\n    }\n  }\n}\n","exit_code":0,"status":"completed"}}
