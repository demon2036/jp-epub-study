{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,220p' /home/john/jp/tests/fixtures/n2_bad_family_plan_wrong_prefix.json\"","aggregated_output":"{\n  \"level\": \"N2\",\n  \"families\": [\n    {\n      \"family_id\": \"f01\",\n      \"family_name\": \"建议・命令系\",\n      \"family_lead\": \"先抓会直接改句意的句末力道\",\n      \"family_hook\": \"这组都是做题时最先判断语气方向的：是建议、义务、禁止，还是邀请、请求、命令。\",\n      \"progression_line\": \"从温和建议到硬性要求，再到直接发话\",\n      \"member_ids\": [\n        \"n4_055_koto_da\",\n        \"n4_085_neba_naranai\",\n        \"n4_164_tewa_naranai\",\n        \"n4_193_you_dewa_nai_ka\",\n        \"n4_128_o_negau\",\n        \"n4_152_tamae\"\n      ]\n    },\n    {\n      \"family_id\": \"f02\",\n      \"family_name\": \"取舍・最低线系\",\n      \"family_lead\": \"比较、退让、保底，一组收好\",\n      \"family_hook\": \"这家人都在做取舍判断：最好、次好、至少先保住哪一条，阅读和完形里很常一起混。\",\n      \"progression_line\": \"从最佳方案到退一步，再到最低底线\",\n      \"member_ids\": [\n        \"n4_094_ni_koshita_koto_wa_nai\",\n        \"n4_010_dake_mashi_da\",\n        \"n4_062_madashimo\",\n        \"n4_137_semete\",\n        \"n4_150_sukunaku_tomo\"\n      ]\n    },\n    {\n      \"family_id\": \"f03\",\n      \"family_name\": \"不得不・忍不住系\",\n      \"family_lead\": \"外在无奈和内心失控放一起看\",\n      \"family_hook\": \"这些形式都带“控制不住/没有别的办法”的压力感，只是有的来自情绪，有的来自现实。\",\n      \"progression_line\": \"从情绪压不住，到局面拖不起，再到只剩这条路\",\n      \"member_ids\": [\n        \"n4_078_nai_dewa_irarenai\",\n        \"n4_159_te_naranai\",\n        \"n4_160_te_tamaranai\",\n        \"n4_163_tewa_irarenai\",\n        \"n4_153_te_bakari_wa_irarenai\",\n        \"n4_191_yori_hoka_nai\",\n        \"n4_196_zaru_o_enai\"\n      ]\n    },\n    {\n      \"family_id\": \"f04\",\n      \"family_name\": \"可能・不可能系\",\n      \"family_lead\": \"先分清能不能，再谈愿不愿\",\n      \"family_hook\": \"这一组都围着“是否做得到”打转，容易跟意志、推量、假设混在一起。\",\n      \"progression_line\": \"从可能到做不到，再到根本没戏\",\n      \"member_ids\": [\n        \"n4_021_eru_uru\",\n        \"n4_020_enai\",\n        \"n4_046_kaneru\",\n        \"n4_054_kkonai\",\n        \"n4_074_mono_nara\"\n      ]\n    },\n    {\n      \"family_id\": \"f05\",\n      \"family_name\": \"文语否定・不做也行系\",\n      \"family_lead\": \"书面味一上来，先认出否定骨架\",\n      \"family_hook\": \"这几个都不是日常口语里的普通 ない，而是考试里高频的书面否定和“不做而了事”表达。\",\n      \"progression_line\": \"从文语否定到不打算，再到不做也能过关\",\n      \"member_ids\": [\n        \"n4_120_nu\",\n        \"n4_063_mai\",\n        \"n4_058_koto_naku\",\n        \"n4_197_zu_ni_sumu\",\n        \"n4_082_nakute_sumu\"\n      ]\n    },\n    {\n      \"family_id\": \"f06\",\n      \"family_name\": \"前提・既然如此系\",\n      \"family_lead\": \"前件一成立，后件就带责任\",\n      \"family_hook\": \"这组都不是单纯条件句，而是“既然都到这一步了，后面就该这样”的前提推进。\",\n      \"progression_line\": \"从既成前提到顺势判断，再到因此必须\",\n      \"member_ids\": [\n        \"n4_050_kara_niwa\",\n        \"n4_032_ijou_wa\",\n        \"n4_183_ue_wa\",\n        \"n4_157_te_koso\",\n        \"n4_144_sore_nara\"\n      ]\n    },\n    {\n      \"family_id\": \"f07\",\n      \"family_name\": \"条件警告・这样下去不行系\",\n      \"family_lead\": \"看到前件，脑中先亮黄灯\",\n      \"family_hook\": \"这些形式都常把句子拉向负面结果、坏习惯或必要前提，是题目里很典型的“警告型条件”。\",\n      \"progression_line\": \"从不满足就不行，到一直这样就糟，再到反复出现更糟\",\n      \"member_ids\": [\n        \"n4_192_you_dewa\",\n        \"n4_156_te_ite_wa\",\n        \"n4_162_tewa_dewa\",\n        \"n4_165_tewa_tewa\",\n        \"n4_079_nai_koto_niwa_nai\"\n      ]\n    },\n    {\n      \"family_id\": \"f08\",\n      \"family_name\": \"让步・两边都成立系\",\n      \"family_lead\": \"无论选哪边，结论都不变\",\n      \"family_hook\": \"这家人专门处理“就算……也……”“不管A还是B”的场景，最容易在选项里互相替代。\",\n      \"progression_line\": \"从单一让步到双项并列，再到来回权衡\",\n      \"member_ids\": [\n        \"n4_180_toshitemo\",\n        \"n4_178_tomo\",\n        \"n4_102_ni_seyo_ni_shiro\",\n        \"n4_103_ni_shiro_ni_shiro\",\n        \"n4_105_ni_shitemo_ni_shitemo\",\n        \"n4_194_you_ka_mai_ka\"\n      ]\n    },\n    {\n      \"family_id\": \"f09\",\n      \"family_name\": \"「ばかり」变脸系\",\n      \"family_lead\": \"同一张脸，四种高频陷阱\",\n      \"family_hook\": \"ばかり 系最容易靠词面误判：它既能说“大约”，也能说“不但”，还能带原因或持续变化。\",\n      \"progression_line\": \"从数量感到追加感，再到原因感和单向变化\",\n      \"member_ids\": [\n        \"n4_003_bakari\",\n        \"n4_005_bakari_ka\",\n        \"n4_006_bakari_ni\",\n        \"n4_004_bakari_da\"\n      ]\n    },\n    {\n      \"family_id\": \"f10\",\n      \"family_name\": \"留余地・别说太满系\",\n      \"family_lead\": \"会留余地，题就不容易做绝\",\n      \"family_hook\": \"这组都在把判断往回收：不是完全否定，不是只因前件就成立，也不是必然如此。\",\n      \"progression_line\": \"从部分保留到条件撤回，再到否定绝对化\",\n      \"member_ids\": [\n        \"n4_081_naku_wa_nai_naku_mo_nai\",\n        \"n4_060_koto_niwa_naranai\",\n        \"n4_053_kara_to_itte\",\n        \"n4_171_to_iu_mono_dewa_nai\"\n      ]\n    },\n    {\n      \"family_id\": \"f11\",\n      \"family_name\": \"「もの」口气系\",\n      \"family_lead\": \"先听出说话人的口气，再抓意思\",\n      \"family_hook\": \"もの 相关语法常靠语气取胜：有解释、有常识、有反驳、有转折，看懂口气就不容易混。\",\n      \"progression_line\": \"从一般常态到主观评价，再到反驳和转折\",\n      \"member_ids\": [\n        \"n4_069_mono_da\",\n        \"n4_072_mono_ga_aru\",\n        \"n4_071_mono_dewa_nai\",\n        \"n4_073_mono_ka_mon_ka\",\n        \"n4_075_monono\"\n      ]\n    },\n    {\n      \"family_id\": \"f12\",\n      \"family_name\": \"理由・正因为如此系\",\n      \"family_lead\": \"不是普通因为，是带立场的因为\",\n      \"family_hook\": \"这些语法都在讲原因，但语气不同：有解释、抱怨、强调，也有推测性的“也许因为”。\",\n      \"progression_line\": \"从说明理由到强调理由，再到带情绪的理由\",\n      \"member_ids\": [\n        \"n4_014_datte\",\n        \"n4_068_mono_mon\",\n        \"n4_070_mono_dakara\",\n        \"n4_056_koto_dakara\",\n        \"n4_135_sei_ka\",\n        \"n4_048_kara_koso\"\n      ]\n    },\n    {\n      \"family_id\": \"f13\",\n      \"family_name\": \"果然・理所当然系\",\n      \"family_lead\": \"看到前件，就觉得后件不意外\",\n      \"family_hook\": \"这组都在表达“难怪”“果然”“本来就该如此”，其中 だけあって／だけに／だけのことはある 最适合和 当然 系一起对比记。\",\n      \"progression_line\": \"从不愧如此到理所当然，再到说出来也不奇怪\",\n      \"member_ids\": [\n        \"n4_009_dake_atte\",\n        \"n4_011_dake_ni\",\n        \"n4_012_dake_no_koto_wa_aru\",\n        \"n4_067_mo_touzen_da\",\n        \"n4_115_no_mo_motto_mo_da\",\n        \"n4_161_te_touzen_da\"\n      ]\n    },\n    {\n      \"family_id\": \"f14\",\n      \"family_name\": \"视角・判断系\",\n      \"family_lead\": \"先定观察点，再读后半句\",\n      \"family_hook\": \"这一组都要先抓“站在谁的角度、凭什么判断”，是阅读题里最典型的立场/根据混淆区。\",\n      \"progression_line\": \"从立场出发到线索判断，再到据此下结论\",\n      \"member_ids\": [\n        \"n4_047_kara_iu_to\",\n        \"n4_104_ni_shitara_ni_sureba\",\n        \"n4_049_kara_miru_to\",\n        \"n4_052_kara_suru_to_kara_sureba\",\n        \"n4_051_kara_shite\",\n        \"n4_117_no_ue_de_wa\",\n        \"n4_177_tokoro_o_miru_to\"\n      ]\n    },\n    {\n      \"family_id\": \"f15\",\n      \"family_name\": \"推量・断定系\",\n      \"family_lead\": \"同样是猜，确信度差很多\",\n      \"family_hook\": \"这一组覆盖了外观判断、推测、学术式判断和强断定，正适合按确信度一口气对比。\",\n      \"progression_line\": \"从看起来像，到大概如此，再到几乎板上钉钉\",\n      \"member_ids\": [\n        \"n4_025_ge\",\n        \"n4_039_ka_no_you_ni\",\n        \"n4_018_dou_yara\",\n        \"n4_130_osoraku\",\n        \"n4_172_to_kangaerareru\",\n        \"n4_093_ni_kimatte_iru\",\n        \"n4_107_ni_soui_nai\"\n      ]\n","exit_code":0,"status":"completed"}}
