{"type":"item.started","item":{"id":"item_9","type":"command_execution","command":"/bin/bash -lc \"python - <<'PY'\nimport json\nobj = {\n  'level': 'N2',\n  'families': [\n    {\n      'family_id': 'f01',\n      'family_name': '建议・命令系',\n      'family_lead': '先抓会直接改句意的句末力道',\n      'family_hook': '这组都是做题时最先判断语气方向的：是建议、义务、禁止，还是邀请、请求、命令。',\n      'progression_line': '从温和建议到硬性要求，再到直接发话',\n      'member_ids': ['n2_055_koto_da','n2_085_neba_naranai','n2_164_tewa_naranai','n2_193_you_dewa_nai_ka','n2_128_o_negau','n2_152_tamae']\n    },\n    {\n      'family_id': 'f02',\n      'family_name': '取舍・最低线系',\n      'family_lead': '比较、退让、保底，一组收好',\n      'family_hook': '这家人都在做取舍判断：最好、次好、至少先保住哪一条，阅读和完形里很常一起混。',\n      'progression_line': '从最佳方案到退一步，再到最低底线',\n      'member_ids': ['n2_094_ni_koshita_koto_wa_nai','n2_010_dake_mashi_da','n2_062_madashimo','n2_137_semete','n2_150_sukunaku_tomo']\n    },\n    {\n      'family_id': 'f03',\n      'family_name': '不得不・忍不住系',\n      'family_lead': '外在无奈和内心失控放一起看',\n      'family_hook': '这些形式都带“控制不住/没有别的办法”的压力感，只是有的来自情绪，有的来自现实。',\n      'progression_line': '从情绪压不住，到局面拖不起，再到只剩这条路',\n      'member_ids': ['n2_078_nai_dewa_irarenai','n2_159_te_naranai','n2_160_te_tamaranai','n2_163_tewa_irarenai','n2_153_te_bakari_wa_irarenai','n2_191_yori_hoka_nai','n2_196_zaru_o_enai']\n    },\n    {\n      'family_id': 'f04',\n      'family_name': '可能・不可能系',\n      'family_lead': '先分清能不能，再谈愿不愿',\n      'family_hook': '这一组都围着“是否做得到”打转，容易跟意志、推量、假设混在一起。',\n      'progression_line': '从可能到做不到，再到根本没戏',\n      'member_ids': ['n2_021_eru_uru','n2_020_enai','n2_046_kaneru','n2_054_kkonai','n2_074_mono_nara']\n    },\n    {\n      'family_id': 'f05',\n      'family_name': '文语否定・不做也行系',\n      'family_lead': '书面味一上来，先认出否定骨架',\n      'family_hook': '这几个都不是日常口语里的普通 ない，而是考试里高频的书面否定和“不做而了事”表达。',\n      'progression_line': '从文语否定到不打算，再到不做也能过关',\n      'member_ids': ['n2_120_nu','n2_063_mai','n2_058_koto_naku','n2_197_zu_ni_sumu','n2_082_nakute_sumu']\n    },\n    {\n      '