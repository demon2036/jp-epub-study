\nprint(obj['properties'].keys())\nPY\"","aggregated_output":"dict_keys(['entry_id', 'card_blurb', 'feel', 'family_position', 'scene_paragraph', 'scene_examples', 'formula', 'formula_explainer', 'structure_cards', 'usage_points', 'contrasts', 'memory_chain'])\n","exit_code":0,"status":"completed"}}
