{"type":"item.completed","item":{"id":"item_2","type":"agent_message","text":"{\n  \"entry_id\": \"n4_088_tara\",\n  \"card_blurb\": \"`сЂЪсѓЅ`тЃЈТіітЅЇтЇітЈЦтЁѕРђюУ┐ЄСИђжЂЇРђЮ№╝џУдЂС╣ѕтЁѕУ«ЙТЃ│AТѕљуФІ№╝їУдЂС╣ѕтЁѕУ«ЕAтЈЉућЪ№╝їуёХтљјтљјтЇітЈЦУЄфуёХТјЦСИіРђюжѓБт░▒РђдРђдРђЮРђюу╗ЊТъют░▒РђдРђдРђЮсђѓ\",\n  \"feel\": \"У┐ЎтЈЦтљгУхиТЮЦтЃЈС║║тюеуј░тю║УЙ╣уюІТЃЁтєхУЙ╣тЙђСИІТјЦУ»Ю№╝џтЁѕтѕ░жѓБСИђТГЦ№╝їтєЇтє│т«џСИІСИђТГЦсђѓТ»ћ`сЂ░`ТЏ┤ТюЅућ╗жЮб№╝їТ»ћ`сЂе`ТЏ┤тЃЈСИђТгАТђДуџёт«ЅТјњТѕќтЈЉуј░сђѓ\",\n  \"family_position\": \"т«ЃтюеТюгт«ХТЌЈжЄїуФЎуџёТў»Рђютю║ТЎ»тїќТЮАС╗Х / тЁѕтЈЉућЪтєЇТјЦу╗ЊТъюРђЮУ┐ЎСИђТа╝сђѓСИЇТў»`сЂ░`жѓБуДЇтЂЈжђ╗УЙЉТЮАС╗Х№╝їСИЇТў»`сЂе`жѓБуДЇтЏ║т«џУДётЙІ№╝їС╣ЪСИЇтЃЈ`сЂфсѓЅ`жѓБТаитЁѕТјЦСйЈт»╣Тќ╣тѕџу╗ЎтЄ║уџёС┐АТЂ»№╝Џ`сЂЪсѓЅ`ТюђтЃЈРђюуГЅAтѕ░С║є№╝їтєЇУ»┤BРђЮсђѓ\",\n  \"scene_paragraph\": \"тЉеТюФу║дТюІтЈІтЄ║жЌеТЌХ№╝їУёЉтГљжЄїтЙѕтИИт░▒Тў»`сЂЪсѓЅ`уџёУіѓтЦЈ№╝џтдѓТъюСИІжЏе№╝їт░▒Тћ╣тј╗тњќтЋАждє№╝Џтѕ░УйдуФЎС║є№╝їт░▒тЈЉТХѕТЂ»№╝ЏУ┐Џтј╗СИђуюІ№╝їТЅЇтЈЉуј░С║║Т»ћТЃ│У▒АСИГтцџсђѓт«ЃСИЇТў»тєитє░тє░тю░тѕЌТЮАС╗Х№╝їУђїТў»ТііС║║ТћЙтЏъуюЪт«ътю║ТЎ»жЄї№╝џAСИђТѕљуФІ№╝їBт░▒жА║уЮђтєњтЄ║ТЮЦ№╝їТЅђС╗ЦТЌбУЃйУ»┤РђютдѓТъюРђЮ№╝їС╣ЪтЙѕтИИУ»┤РђюРђдРђдС╣ІтљјРђЮРђюСИђРђдРђдт░▒РђдРђдРђЮсђѓ\",\n  \"scene_examples\": [\n    {\n      \"tag\": \"ТјЦуФЎ\",\n      \"jp_ruby\": \"жДЁ[сЂѕсЂЇ]сЂФуЮђ[сЂц]сЂёсЂЪсѓЅсђЂLINEсЂЌсЂдсђѓУ┐ј[сѓђсЂІ]сЂѕсЂФУАї[сЂё]сЂЈсЂІсѓЅсђѓ\",\n      \"zh\": \"тѕ░УйдуФЎтљју╗ЎТѕЉтЈЉСИф LINE№╝їТѕЉтј╗ТјЦСйасђѓ\",\n      \"note\": \"тЅЇжА╣СИђт«їТѕљ№╝їтљјжА╣т░▒Тў»СИІСИђТГЦт«ЅТјњсђѓ\"\n    },\n    {\n      \"tag\": \"У»ЋтљЃ\",\n      \"jp_ruby\": \"СИђтЈБ[сЂ▓сЂесЂЈсЂА]жБ▓[сЂ«]сѓЊсЂасѓЅсђЂТђЮ[сЂісѓѓ]сЂБсЂЪсѓѕсѓіУЙЏ[сЂІсѓЅ]сЂІсЂБсЂЪсђѓ\",\n      \"zh\": \"тќЮС║єСИђтЈБ№╝їТЅЇтЈЉуј░Т»ћТЃ│уџёУЙБсђѓ\",\n      \"note\": \"тЙѕтЁИтъІуџёРђюСИђРђдРђдт░▒тЈЉуј░РђдРђдРђЮУ»ГТёЪсђѓ\"\n    },\n    {\n      \"tag\": \"СИІуЈГтљј\",\n      \"jp_ruby\": \"ТЎѓжќЊ[сЂўсЂІсѓЊ]сЂїсЂѓсЂБсЂЪсѓЅсђЂтИ░[сЂІсЂѕ]сѓісЂФт░Љ[сЂЎсЂЊ]сЂЌУЕ▒[сЂ»сЂф]сЂЮсЂєсђѓ\",\n      \"zh\": \"тдѓТъюТюЅТЌХжЌ┤№╝їтЏътј╗Уи»СИіУЂіСИђС╝џтё┐тљДсђѓ\",\n      \"note\": \"СИЇТў»ТГ╗ТЮАС╗Х№╝їУђїТў»СИ┤тю║уюІТЃЁтєхуџёТЈљУ««сђѓ\"\n    }\n  ],\n  \"formula\": \"VсЂЪсѓЅ / сЂёAсЂІсЂБсЂЪсѓЅ / сЂфAсЂасЂБсЂЪсѓЅ / NсЂасЂБсЂЪсѓЅ\",\n  \"formula_explainer\": \"`сЂЪсѓЅ`уџёТаИт┐ЃСИЇТў»РђюУ┐Єтј╗РђЮ№╝їУђїТў»ТіітЅЇжА╣тЁѕтцёуљєТѕљРђюти▓ТѕљуФІ / ти▓тЈЉућЪРђЮуџёТаитГљ№╝їтєЇТјЦтљјжА╣сђѓТЅђС╗ЦтіеУ»ЇућесЂЪтйбТјЦ`сѓЅ`№╝їсЂётйбт«╣У»Їуће`сЂІсЂБсЂЪсѓЅ`№╝їсЂфтйбт«╣У»ЇтњїтљЇУ»Їуће`сЂасЂБсЂЪсѓЅ`сђѓС║јТў»т«ЃТЌбУЃйУАеуц║РђютдѓТъюAРђЮ№╝їС╣ЪУЃйУАеуц║РђюAС╣Ітљј / AТЌХт░▒РђдРђдРђЮсђѓ\",\n  \"structure_cards\": [\n    {\n      \"label\": \"тЁѕтЂџA№╝їтєЇтЂџB\",\n      \"note\": \"тіеСйют«їТѕљтљјТјЦСИІСИђТГЦ\",\n      \"jp_ruby\": \"т«Х[сЂёсЂѕ]сЂФтИ░[сЂІсЂѕ]сЂБсЂЪсѓЅсђЂсЂЙсЂџТЅІ[сЂд]сѓњТ┤Ќ[сЂѓсѓЅ]сЂБсЂдсђѓ\",\n      \"zh\": \"тЏът«ХтљјтЁѕТ┤ЌТЅІсђѓ\",\n      \"mini_note\": \"`сЂЪсѓЅ`тЙѕжђѓтљѕТјЦТЈљжєњсђЂТїЄуц║сђЂСИІСИђТГЦтіеСйюсђѓ\"\n    },\n    {\n      \"label\": \"тдѓТъюA№╝їт░▒ТЃ│/т░▒УдЂB\",\n      \"note\": \"тю║ТЎ»тЂЄУ«Й\",\n      \"jp_ruby\": \"т«Ѕ[сѓёсЂЎ]сЂІсЂБсЂЪсѓЅсђЂсЂЊсЂ«жЮ┤[сЂЈсЂц]сѓњУ▓и[сЂІ]сЂёсЂЪсЂёсђѓ\",\n      \"zh\": \"тдѓТъюСЙ┐т«юуџёУ»Ю№╝їТѕЉТЃ│С╣░У┐ЎтЈїжъІсђѓ\",\n      \"mini_note\": \"тљјжА╣ТћЙТё┐ТюЏсђЂТЅЊу«Ќ№╝їтЙѕУЄфуёХсђѓ\"\n    },\n    {\n      \"label\": \"СИђA№╝їт░▒тЈЉуј░B\",\n      \"note\": \"у╗ЊТъютюетіеСйютљјтєњтЄ║ТЮЦ\",\n      \"jp_ruby\": \"сЃЅсѓбсѓњжќІ[сЂѓ]сЂЉсЂЪсѓЅсђЂуїФ[сЂГсЂЊ]сЂїтцќ[сЂЮсЂе]сЂФсЂёсЂЪсђѓ\",\n      \"zh\": \"жЌеСИђТЅЊт╝ђ№╝їтЈЉуј░уїФтюетцќжЮбсђѓ\",\n      \"mini_note\": \"У┐Ўу▒╗тЈЦтГљтИИтИдСИђуѓ╣РђютјЪТЮЦтдѓТГц/Т▓АТЃ│тѕ░РђЮуџёуј░тю║ТёЪсђѓ\"\n    }\n  ],\n  \"usage_points\": [\n    \"`сЂЪсѓЅ`ТюђтИИУДЂуџёТёЪУДЅ№╝їТў»ТіітЅЇжА╣тйЊТѕљРђютЁѕТѕљуФІуџёТЮАС╗ХРђЮсђѓТЅђС╗Цт«ЃуЅ╣тѕФжђѓтљѕРђютѕ░С║єт░▒УЂћу│╗ТѕЉРђЮРђюТюЅуЕ║т░▒СИђУхитј╗РђЮУ┐ЎуДЇжА║ТјЦСИІСИђТГЦуџёУ»Юсђѓ\",\n    \"т«ЃуџётљјжА╣тЙѕУЄфућ▒№╝їУЃйТјЦУ»иТ▒ѓсђЂтЉйС╗цсђЂт╗║У««сђЂТёЈт┐ЌсђЂТё┐ТюЏсђѓтЃЈ`уЮђ[сЂц]сЂёсЂЪсѓЅжђБухА[сѓїсѓЊсѓЅсЂЈ]сЂЌсЂд`сђЂ`т«Ѕ[сѓёсЂЎ]сЂІсЂБсЂЪсѓЅУ▓и[сЂІ]сЂісЂє`жЃйтЙѕУЄфуёХ№╝їУ┐ЎСИђуѓ╣Т»ћ`сЂе`т«йтЙѕтцџсђѓ\",\n    \"т«ЃТЌбУЃйу┐╗ТѕљРђютдѓТъюРђЮ№╝їС╣ЪУЃйу┐╗ТѕљРђюРђдРђдС╣ІтљјРђЮсђѓтЁ│жћ«уюІтЈЦтГљТў»СИЇТў»ТЌХжЌ┤жА║ТјЦсђѓ`т«Х[сЂёсЂѕ]сЂФтИ░[сЂІсЂѕ]сЂБсЂЪсѓЅ`тцџтЇіТў»РђютЏът«ХтљјРђЮ№╝ї`жЏе[сЂѓсѓЂ]сЂасЂБсЂЪсѓЅ`тцџтЇіТў»РђютдѓТъюСИІжЏеРђЮсђѓ\",\n    \"`сЂЪсѓЅ`тЙѕуѕ▒тЄ║уј░тюеРђютЂџС║єТЅЇуЪЦжЂЊРђЮуџётЈЦтГљжЄї№╝џ`жќІ[сЂѓ]сЂЉсЂЪсѓЅУф░[сЂасѓї]сѓѓсЂёсЂфсЂІсЂБсЂЪ`сђѓУ┐ЎТЌХжЄЇуѓ╣СИЇтюетЂЄУ«Й№╝їУђїтюеу╗ЊТъюТў»AС╣ІтљјТЅЇуюІУДЂуџёсђѓ\",\n    \"`сЂЪ`тюеУ┐ЎжЄїСИ╗УдЂТў»ТјЦу╗Гтйбт╝Ј№╝їСИЇуГЅС║јТЋ┤тЈЦСИђт«џтюеУ»┤У┐Єтј╗сђѓ`т«Ѕ[сѓёсЂЎ]сЂІсЂБсЂЪсѓЅУ▓и[сЂІ]сЂє`У»┤уџёт«їтЁетЈ»С╗ЦТў»ТюфТЮЦТЅЊу«Ќсђѓ\",\n    \"ТЃ│ТіЊт«ЃуџёУ»ГТёЪ№╝їт░▒У«░СйЈСИђтЈЦУ»Ю№╝џ`сЂЪсѓЅ`СИЇТў»тюеУ«▓ТійУ▒АТЮАС╗Х№╝їУђїТў»тюеУ«▓РђюуГЅС║ІТЃЁУх░тѕ░жѓБСИђТГЦ№╝їтєЇТјЦСИІтј╗РђЮсђѓ\"\n  ],\n  \"contrasts\": [\n    {\n      \"other_entry_id\": \"n4_005_ba\",\n      \"title\": \"сЂЪсѓЅ vs сЂ░\",\n      \"self_label\": \"тю║ТЎ»жЄїСИ┤ТЌХУхиТёЈуџёТЮАС╗Х\",\n      \"other_label\": \"жђ╗УЙЉСИіТ╗АУХ│т░▒ТѕљуФІуџёТЮАС╗Х\",\n      \"difference\": \"`сЂЪсѓЅ`ТЏ┤тЃЈТііС║║ТћЙУ┐ЏтЁиСйЊтю║ТЎ»жЄї№╝їУ»┤РђютдѓТъюуюЪтѕ░жѓБСИђТГЦ№╝їТѕЉС╗гт░▒У┐ЎС╣ѕтЂџРђЮ№╝Џ`сЂ░`ТЏ┤тЃЈТійтЄ║ТЮАС╗ХтЁ│у│╗№╝їУ»┤РђютЈфУдЂТЮАС╗ХТ╗АУХ│№╝їт░▒УЃй/т░▒С╝џРђдРђдРђЮсђѓ\",\n      \"example_self\": {\n        \"jp_ruby\": \"ТЎѓжќЊ[сЂўсЂІсѓЊ]сЂїсЂѓсЂБсЂЪсѓЅсђЂТўаућ╗[сЂѕсЂёсЂї]сѓњУдІ[сЂ┐]сЂФУАї[сЂё]сЂЊсЂєсђѓ\",\n        \"zh\": \"тдѓТъюТюЅТЌХжЌ┤№╝їТѕЉС╗гт░▒тј╗уюІућхтй▒тљДсђѓ\",\n        \"note\": \"тљјжА╣Тў»ТЈљУ««№╝їтИдС║║уџёТЅЊу«Ќсђѓ\"\n      },\n      \"example_other\": {\n        \"jp_ruby\": \"ТЎѓжќЊ[сЂўсЂІсѓЊ]сЂїсЂѓсѓїсЂ░сђЂТўаућ╗[сЂѕсЂёсЂї]сѓњУдІ[сЂ┐]сЂФУАї[сЂё]сЂЉсѓІсђѓ\",\n        \"zh\": \"тдѓТъюТюЅТЌХжЌ┤№╝їт░▒УЃйтј╗уюІућхтй▒сђѓ\",\n        \"note\": \"тљјжА╣Тў»ТЮАС╗ХТѕљуФІтљјуџётЈ»УЃйу╗ЊТъюсђѓ\"\n      },\n      \"exam_handle\": \"уЕ║Та╝тљјжЮбтдѓТъюТў»`УАї[сЂё]сЂЊсЂє`сђЂ`сђюсЂд`сђЂ`сђюсЂЪсЂё`У┐Ўу▒╗С║║уџёТёЈт┐ЌсђЂжѓђУ»исђЂУ»иТ▒ѓ№╝їтЁѕТЃ│`сЂЪсѓЅ`№╝ЏтдѓТъютљјжЮбТЏ┤тЃЈ`УАї[сЂё]сЂЉсѓІ`сђЂ`тѕє[сѓЈ]сЂІсѓІ`У┐Ўу▒╗ТЮАС╗ХСИђТ╗АУХ│т░▒УЄфуёХТѕљуФІуџёу╗ЊТъю№╝їтЂЈ`сЂ░`сђѓ\"\n    },\n    {\n      \"other_entry_id\": \"n4_054_nara\",\n      \"title\": \"сЂЪсѓЅ vs сЂфсѓЅ\",\n      \"self_label\": \"уГЅAуюЪуџётЈЉућЪ/УдЂтЈЉућЪ№╝їтєЇТјЦB\",\n      \"other_label\": \"ТЌбуёХУ»┤тѕ░AУ┐ЎСИфтЅЇТЈљ№╝їт░▒жА║уЮђУАЦСИђтЈЦ\",\n      \"difference\": \"`сЂЪсѓЅ`ТііжЄЇт┐ЃТћЙтюеAТѕљуФІС╣ІтљјуџёСИІСИђТГЦ№╝Џ`сЂфсѓЅ`тИИтИИТў»ТјЦСйЈт»╣Тќ╣тѕџУ»┤тЄ║ТЮЦуџёУ«АтѕњсђЂС┐АТЂ»ТѕќУ»Южбў№╝їУ»ГТёЪТЏ┤тЃЈРђюТЌбуёХТў»жѓБТаиуџёУ»ЮРђдРђдРђЮсђѓ\",\n      \"example_self\": {\n        \"jp_ruby\": \"сЂЮсЂ«т║Ќ[сЂ┐сЂЏ]сЂФУАї[сЂё]сЂБсЂЪсѓЅсђЂуДЂ[сѓЈсЂЪсЂЌ]сЂФсѓѓсѓ▒сЃ╝сѓГсѓњУ▓и[сЂІ]сЂБсЂдсЂЇсЂдсђѓ\",\n        \"zh\": \"СйаУдЂТў»тј╗С║єжѓБт«Хт║Ќ№╝їС╣ЪтИ«ТѕЉтИдтЮЌУЏІу│ЋтљДсђѓ\",\n        \"note\": \"жЄЇуѓ╣Тў»Рђютѕ░ТЌХтђЎуюЪтј╗С║єуџёУ»ЮРђЮсђѓ\"\n      },\n      \"example_other\": {\n        \"jp_ruby\": \"сЂЮсЂ«т║Ќ[сЂ┐сЂЏ]сЂФУАї[сЂё]сЂЈсЂфсѓЅсђЂуДЂ[сѓЈсЂЪсЂЌ]сЂФсѓѓсѓ▒сЃ╝сѓГсѓњУ▓и[сЂІ]сЂБсЂдсЂЇсЂдсђѓ\",\n        \"zh\": \"ТЌбуёХСйаУдЂтј╗жѓБт«Хт║Ќ№╝їС╣ЪтИ«ТѕЉтИдтЮЌУЏІу│ЋтљДсђѓ\",\n        \"note\": \"ТўјТўЙТў»тюеТјЦт»╣Тќ╣ти▓ТюЅуџёУ«Атѕњсђѓ\"\n      },\n      \"exam_handle\": \"тдѓТъюжбўуЏ«тЃЈтюетЏът║ћтЅЇТќЄС┐АТЂ»сђЂТјЦСйЈтѕФС║║тѕџУ»┤уџёУ»Ю№╝їС╝ўтЁѕуюІ`сЂфсѓЅ`№╝ЏтдѓТъютЈфТў»тЇЋу║»УАеУЙЙРђюуГЅAтЈЉућЪС║є№╝їтєЇтЂџBРђЮ№╝їт░▒ТЏ┤тЃЈ`сЂЪсѓЅ`сђѓ\"\n    },\n    {\n      \"other_entry_id\": \"n4_108_to\",\n      \"title\": \"сЂЪсѓЅ vs сЂе\",\n      \"self_label\": \"СИђТгАТђДуџёт«ЅТјњсђЂУ»иТ▒ѓсђЂтЈЉуј░\",\n      \"other_label\": \"СИђтѕ░жѓБСИфТЮАС╗Хт░▒Тђ╗С╝џтЄ║уј░уџёу╗ЊТъю\",\n      \"difference\": \"`сЂЪсѓЅ`тЈ»С╗ЦУ»┤СИђТгАТђДуџётіеСйют«ЅТјњ№╝їС╣ЪУЃйУ»┤ТёЈтцќтЈЉуј░№╝Џ`сЂе`ТЏ┤тЃЈт«бУДѓУДётЙІсђЂС╣аТЃ»у╗ЊТъю№╝їтљјжА╣жђџтИИСИЇТў»У»┤У»ЮС║║СИ┤ТЌХСИІуџётЉйС╗цТѕќТЅЊу«Ќсђѓ\",\n      \"example_self\": {\n        \"jp_ruby\": \"жДЁ[сЂѕсЂЇ]сЂФуЮђ[сЂц]сЂёсЂЪсѓЅсђЂжЏ╗УЕ▒[сЂДсѓЊсѓЈ]сЂЌсЂдсЂЈсЂасЂЋсЂёсђѓ\",\n        \"zh\": \"тѕ░УйдуФЎтљјУ»иу╗ЎТѕЉТЅЊућхУ»Юсђѓ\",\n        \"note\": \"Тў»СИђТгАТђДуџёУ»иТ▒ѓсђѓ\"\n      },\n      \"example_other\": {\n        \"jp_ruby\": \"жДЁ[сЂѕсЂЇ]сЂФуЮђ[сЂц]сЂЈсЂесђЂсЂёсЂцсѓѓжЏ╗УЕ▒[сЂДсѓЊсѓЈ]сЂЌсЂдсЂЈсѓїсѓІсђѓ\",\n        \"zh\": \"СйаСИђтѕ░УйдуФЎ№╝їТђ╗С╝џу╗ЎТѕЉТЅЊућхУ»Юсђѓ\",\n        \"note\": \"Тў»тюеУ»┤С╣аТЃ»ТђДуџёу╗ЊТъюсђѓ\"\n      },\n      \"exam_handle\": \"тљјжА╣тдѓТъюТў»У»иТ▒ѓсђЂтЉйС╗цсђЂжѓђУ»исђЂУ«Атѕњ№╝їтЪ║ТюгтЁѕТјњжЎц`сЂе`№╝їтцџтЇіжђЅ`сЂЪсѓЅ`№╝ЏтдѓТъютЈЦтГљтюеУ»┤РђюТ»ЈТгАСИђAт░▒BРђЮУ┐ЎуДЇтЏ║т«џУДётЙІТѕќС╣аТЃ»№╝їтєЇУђЃУЎЉ`сЂе`сђѓ\"\n    }\n  ],\n  \"memory_chain\": \"ТііУ┐ЎСИђт«ХУ┐ЎТаиСИ▓УхиТЮЦУ«░Тюђуе│№╝џ`сЂе`тЃЈт╝ђтЁ│№╝їСИђТїЅт░▒тЏ║т«џтЈЉућЪ№╝Џ`сЂ░`тЃЈТЮАС╗ХтЁгт╝Ј№╝їТ╗АУХ│т░▒ТѕљуФІ№╝Џ`сЂЪсѓЅ`тЃЈжЋютц┤ТјеУ┐Џтѕ░уј░тю║№╝їуГЅAтѕ░С║єжѓБСИђТГЦтєЇТјЦB№╝Џ`сЂфсѓЅ`тЃЈТјЦСйЈую╝тЅЇУ»ЮжбўУ»┤РђюТЌбуёХУ┐ЎТаиРђЮ№╝Џ`та┤тљѕ[сЂ░сЂѓсЂё]сЂ»`тѕЎтЃЈУ»┤ТўјС╣джЄїуџёТГБт╝ЈтѕєТћ»сђѓУ«░`сЂЪсѓЅ`ТЌХ№╝їтЈфТіЊСйЈт«ЃуџёТаИт┐Ѓуј░тю║ТёЪт░▒тцЪС║є№╝џтЁѕтЈЉућЪсђЂтЁѕТѕљуФІсђЂтєЇтЈЇт║ћсђѓ\"\n}"}}
